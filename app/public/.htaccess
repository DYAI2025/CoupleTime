# CoupleTimer – Hostinger Apache config
# SPA Fallback: alle Routen → index.html
Options -MultiViews
RewriteEngine On
RewriteBase /

# Statische Dateien direkt servieren
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Alles andere → index.html (SPA-Routing)
RewriteRule ^ index.html [L]

# Security Headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache-Control für Assets
<IfModule mod_expires.c>
  ExpiresActive On
  # JS/CSS mit Hash → 1 Jahr
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  # Bilder
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # HTML → kein Cache (index.html muss immer frisch sein)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# GZIP Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
